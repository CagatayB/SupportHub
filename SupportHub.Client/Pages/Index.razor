@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav

<div class="container mt-5">
    <div class="row align-items-center">
        <div class="col-lg-6">
            <h1 class="display-4 fw-bold text-primary">SupportHub</h1>
            <p class="lead mt-3">
                Modern, hızlı ve güvenilir destek talep yönetim sistemi. 
                Müşterilerinizle olan iletişiminizi dijitalleştirin ve çözüm süreçlerinizi hızlandırın.
            </p>
            <div class="mt-4">
                <AuthorizeView>
                    <Authorized>
                        <button class="btn btn-primary btn-lg px-4 me-2" @onclick='() => Nav.NavigateTo("/dashboard")'>
                            Dashboard'a Git
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <button class="btn btn-primary btn-lg px-4 me-2" @onclick='() => Nav.NavigateTo("/login")'>
                            Giriş Yap
                        </button>
                        <button class="btn btn-outline-secondary btn-lg px-4" @onclick='() => Nav.NavigateTo("/register")'>
                            Kayıt Ol
                        </button>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>

    <div class="row mt-5 pt-5 text-center">
        <div class="col-md-4">
            <i class="bi bi-lightning-charge-fill text-warning fs-1"></i>
            <h4 class="mt-3">Hızlı Çözüm</h4>
            <p class="text-muted">Anlık bildirimler ve SignalR ile kesintisiz iletişim.</p>
        </div>
        <div class="col-md-4">
            <i class="bi bi-shield-lock-fill text-success fs-1"></i>
            <h4 class="mt-3">Güvenli Altyapı</h4>
            <p class="text-muted">JWT ve Rol tabanlı yetkilendirme ile verileriniz güvende.</p>
        </div>
        <div class="col-md-4">
            <i class="bi bi-graph-up text-danger fs-1"></i>
            <h4 class="mt-3">Detaylı Analiz</h4>
            <p class="text-muted">Dashboard üzerinden tüm taleplerinizi anlık takip edin.</p>
        </div>
    </div>
</div>