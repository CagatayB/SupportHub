@page "/ticket/{Id:int}"
@using Microsoft.AspNetCore.SignalR.Client
@using SupportHub.Application.DTOs.Message
@using SupportHub.Application.DTOs.Ticket
@using SupportHub.Client.Services
@inject TicketClientService TicketService
@inject NavigationManager Nav
@implements IAsyncDisposable

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Talep Detayı</li>
                </ol>
            </nav>
            <h2 class="fw-bold">#@Id - @currentTicket?.Title</h2>
        </div>
        <div class="text-end">
            <span class="badge @GetPriorityClass(currentTicket?.Priority) p-2 mb-2">@currentTicket?.Priority Öncelik</span>
            <div class="h4"><span class="badge @GetStatusClass(currentTicket?.Status) shadow-sm">@currentTicket?.Status</span></div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 flex-column" style="height: 600px;">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="mb-0"><i class="bi bi-chat-dots me-2 text-primary"></i>İşlem Geçmişi</h5>
                </div>
                
                <div class="card-body overflow-auto bg-light p-4" id="chatContainer">
                    @foreach (var msg in messages)
                    {
                        <div class="d-flex mb-4 @(msg.IsOwner ? "justify-content-end" : "justify-content-start")">
                            <div class="max-w-75">
                                <div class="small text-muted mb-1 @(msg.IsOwner ? "text-end" : "")">
                                    <strong>@msg.UserName</strong> • @msg.CreatedAt.ToString("HH:mm")
                                </div>
                                <div class="p-3 rounded-3 shadow-sm @(msg.IsOwner ? "bg-primary text-white" : "bg-white text-dark")" 
                                     style="border-radius: @(msg.IsOwner ? "15px 15px 0 15px" : "15px 15px 15px 0") !important;">
                                    @msg.MessageText
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="card-footer bg-white border-top-0 py-3">
                    <div class="input-group input-group-lg">
                        <input type="text" class="form-control border-2" 
                               @bind="newMessage" @onkeyup="HandleKeyPress"
                               placeholder="Mesajınızı buraya yazın..." />
                        <button class="btn btn-primary px-4" @onclick="SendMessage">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted fw-bold mb-3">Talep Bilgileri</h6>
                    <ul class="list-unstyled">
                        <li class="mb-3 d-flex justify-content-between">
                            <span class="text-muted">Oluşturulma:</span>
                            <span>@currentTicket?.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                        </li>
                        <li class="mb-3 d-flex justify-content-between">
                            <span class="text-muted">Son Güncelleme:</span>
                            <span>@(currentTicket?.UpdatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</span>
                        </li>
                        <li class="mb-3 d-flex justify-content-between">
                            <span class="text-muted">Müşteri:</span>
                            <span class="fw-bold">@currentTicket?.CreatedByUserId</span>
                        </li>
                    </ul>
                    <hr />
                    <h6 class="text-uppercase text-muted fw-bold mb-2">Açıklama</h6>
                    <p class="text-secondary small">@currentTicket?.Description</p>
                </div>
            </div>

            @* <AuthorizeView Roles="Admin,SupportStaff"> *@
    <div class="card shadow-sm border-0 bg-dark text-white overflow-hidden">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="text-uppercase fw-bold mb-0 text-info">Yönetim Paneli</h6>
                @if (isUpdating)
                {
                    <div class="spinner-border spinner-border-sm text-info" role="status"></div>
                }
            </div>
            
            <div class="mb-3">
                <label class="small mb-2 text-light-50">Durumu Güncelle</label>
                <select class="form-select bg-secondary text-white border-0" 
                        @onchange="OnStatusChanged" 
                        disabled="@isUpdating">
                    <option value="1" selected='@(currentTicket?.Status == "Open")'>Açık</option>
                    <option value="2" selected='@(currentTicket?.Status == "In Progress")'>İşleniyor</option>
                    <option value="3" selected='@(currentTicket?.Status == "Resolved")'>Çözüldü</option>
                    <option value="4" selected='@(currentTicket?.Status == "Closed")'>Kapatıldı</option>
                </select>
            </div>

            @* <AuthorizeView Roles="Admin,SupportStaff"> *@
    @if (currentTicket?.AssignedToUserId == null)
    {
        <div class="mt-3 p-3 bg-light border rounded">
            <p class="small text-muted">Bu talep henüz bir personele atanmamış.</p>
            <button class="btn btn-primary w-100 fw-bold" @onclick="HandleAssign">
                <i class="bi bi-person-check me-2"></i>Talebi Üzerime Al
            </button>
        </div>
    }
    else
    {
        <div class="mt-3 p-2 bg-success bg-opacity-10 text-success border border-success rounded small">
            <i class="bi bi-check-circle-fill me-2"></i>
            @if (!string.IsNullOrEmpty(currentTicket?.AssignedToUserId)) // Yeni eklediğimiz isim alanı
            {
                <span>Bu talep <strong>@currentTicket.AssignedToUserId</strong> tarafından devralındı.</span>
            }
            else if (currentTicket?.AssignedToUserId != null)
            {
                <span>Bu talep <strong>@currentTicket.AssignedToUserId</strong> tarafından devralındı.</span>
            }
        </div>
    }
@* </AuthorizeView> *@
        </div>
    </div>
@* </AuthorizeView> *@
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private TicketDto? currentTicket;
    private List<MessageDto> messages = new();
    private string newMessage = "";

    private string GetStatusClass(string? status) => status switch
    {
        "Open" => "bg-danger",
        "InProgress" => "bg-warning text-dark",
        "Resolved" => "bg-success",
        _ => "bg-secondary"
    };

    private string GetPriorityClass(string? priority) => priority switch
    {
        "High" or "Urgent" => "bg-danger text-white",
        "Medium" => "bg-info text-dark",
        _ => "bg-light text-dark border"
    };

    private bool isUpdating = false;

    private async Task OnStatusChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newStatus))
        {
            isUpdating = true;
            StateHasChanged();

            // API'ye PATCH isteği gönderiyoruz
            var success = await TicketService.UpdateStatusAsync(Id, newStatus);
        
            if (success)
            {
                // UI'daki mevcut ticket objesini güncelle (SignalR yayınından önce anlık feedback)
                if (currentTicket != null)
                {
                    currentTicket.Status = GetStatusName(newStatus);
                }
            
                // Opsiyonel: "Durum Güncellendi" şeklinde bir bildirim/toast gösterilebilir.
            }
        
            isUpdating = false;
            StateHasChanged();
        }
    }

    private string GetStatusName(int status) => status switch
    {
        1 => "Open",
        2 => "InProgress",
        3 => "Resolved",
        4 => "Closed",
        _ => "Unknown"
    };


    protected override async Task OnInitializedAsync()
    {
        // Talebi ve eski mesajları yükle
        currentTicket = await TicketService.GetTicketDetailAsync(Id);
        messages = await TicketService.GetTicketMessagesAsync(Id);

        await TicketService.StartAsync();


        if (TicketService.HubConnection.State == HubConnectionState.Connected)
        {
            await JoinGroup();
        }

        else
        {
            // Retry logic
            int retryCount = 0;
            while (TicketService.HubConnection.State != HubConnectionState.Connected && retryCount < 10)
            {
                await Task.Delay(500);
                retryCount++;
            }
        
            if (TicketService.HubConnection.State == HubConnectionState.Connected)
                await JoinGroup();
        }

        // Mesaj dinleyiciyi her durumda kur
        TicketService.HubConnection.On<MessageDto>("ReceiveMessage", (msg) =>
        {
            if (msg.TicketId == Id)
            {
                messages.Add(msg);
                InvokeAsync(StateHasChanged);
            }
        });
    }

    private async Task JoinGroup()
    {
        await TicketService.HubConnection.InvokeAsync("JoinTicketGroup", Id);
    }


    // Mesaj gönderme işlemi
    private async Task SendMessage()
    {
        if (!string.IsNullOrWhiteSpace(newMessage))
        {
            await TicketService.SendMessageAsync(Id, newMessage);
            newMessage = "";
        }
    }

    private async Task HandleAssign()
    {
        var success = await TicketService.AssignTicketAsync(Id);
        if (success)
        {
            currentTicket = await TicketService.GetTicketDetailAsync(Id);
            StateHasChanged();
        }
        else
        {
            Console.WriteLine("Atama işlemi başarısız.");
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    public async ValueTask DisposeAsync()
    {
        // Sayfadan ayrılırken SignalR grubundan çık
        if (TicketService.HubConnection is not null)
            await TicketService.HubConnection.InvokeAsync("LeaveTicketGroup", Id);
    }
}