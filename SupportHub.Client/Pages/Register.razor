@page "/register"
@using SupportHub.Application.DTOs.Auth
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-body p-4">
                    <h3 class="card-title text-center mb-4">Yeni Hesap Oluştur</h3>
                    
                    <EditForm Model="registerModel" OnValidSubmit="HandleRegister">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-3">
                            <label class="form-label">Kullanıcı Adı</label>
                            <InputText @bind-Value="registerModel.Username" class="form-control" placeholder="cagataybeser" />
                            <ValidationMessage For="@(() => registerModel.Username)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">E-posta</label>
                            <InputText @bind-Value="registerModel.Email" class="form-control" placeholder="ornek@mail.com" />
                            <ValidationMessage For="@(() => registerModel.Email)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Şifre</label>
                            <InputText @bind-Value="registerModel.Password" type="password" class="form-control" />
                            <ValidationMessage For="@(() => registerModel.Password)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Şifre Tekrar</label>
                            <InputText @bind-Value="registerModel.ConfirmPassword" type="password" class="form-control" />
                            <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="text-danger small" />
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger small">@errorMessage</div>
                        }

                        <button type="submit" class="btn btn-success w-100 mt-2" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm"></span> <span>Kaydediliyor...</span>
                            }
                            else
                            {
                                <span>Kayıt Ol</span>
                            }
                        </button>
                    </EditForm>

                    <div class="text-center mt-3">
                        <p class="small">Zaten hesabınız var mı? <a href="/login">Giriş Yap</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerModel = new();
    private string? errorMessage;
    private bool isSubmitting = false;

    private async Task HandleRegister()
    {
        isSubmitting = true;
        errorMessage = null;

        var response = await Http.PostAsJsonAsync("api/auth/register", registerModel);

        if (response.IsSuccessStatusCode)
        {
            // Kayıt başarılı, kullanıcıyı giriş sayfasına yönlendir
            Nav.NavigateTo("/login?registered=true");
        }
        else
        {
            errorMessage = "Kayıt sırasında bir hata oluştu. Kullanıcı adı veya e-posta kullanımda olabilir.";
        }
        
        isSubmitting = false;
    }
}